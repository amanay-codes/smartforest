DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: one shared PostgreSQL connection string for all machines.
# If DATABASE_URL is set, it overrides the DB_ENGINE/DB_* settings below.
# Example:
# DATABASE_URL=postgresql://shared_user:shared_password@your-db-host:5432/smartforest?sslmode=prefer
DATABASE_URL=

# Default local setup. Each developer gets their own db.sqlite3 file.
DB_ENGINE=sqlite
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
DB_SSLMODE=prefer

# To share registrations between computers, use DB_ENGINE=postgresql and set
# DB_HOST to a real shared database host, not localhost.

# Optional Cloudinary uploads. Leave USE_CLOUDINARY=False for local media.
USE_CLOUDINARY=False
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
