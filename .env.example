DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Recommended Neon/PostgreSQL setup.
# Copy the connection string from Neon and replace the password placeholder.
# DATABASE_URL overrides the DB_ENGINE/DB_* settings below.
DATABASE_URL=postgresql://neondb_owner:your_password_here@ep-morning-darkness-al4cl046-pooler.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Alternative PostgreSQL settings if DATABASE_URL is empty.
DB_ENGINE=postgresql
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=your_password_here
DB_HOST=ep-morning-darkness-al4cl046-pooler.c-3.eu-central-1.aws.neon.tech
DB_PORT=5432
DB_SSLMODE=require

# Optional Cloudinary uploads. Leave USE_CLOUDINARY=False for local media.
USE_CLOUDINARY=False
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
